# IntelliK8sBot Configuration
# Copy this file to .env and fill in your values

# ============================================
# OpenAI Configuration (Required for AI features)
# ============================================
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview

# ============================================
# Kubernetes Configuration
# ============================================
# Leave empty to use default kubeconfig (~/.kube/config)
KUBECONFIG_PATH=
# Set to "true" if running inside a Kubernetes cluster
IN_CLUSTER=false
# Default namespace for operations
DEFAULT_NAMESPACE=default

# ============================================
# Application Settings
# ============================================
APP_NAME=IntelliK8sBot
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# API Server Configuration
API_HOST=0.0.0.0
API_PORT=8000

# ============================================
# Database Configuration
# ============================================
DATABASE_URL=sqlite+aiosqlite:///./data/intellik8s.db

# ============================================
# Security Settings
# ============================================
# Enable/disable dangerous operations (delete, scale to 0, etc.)
ALLOW_DESTRUCTIVE_OPERATIONS=false
# Require confirmation for critical operations
REQUIRE_CONFIRMATION=true

# ============================================
# Feature Flags
# ============================================
ENABLE_AUTO_REMEDIATION=false
ENABLE_COST_ANALYSIS=true
ENABLE_RESOURCE_RECOMMENDATIONS=true
